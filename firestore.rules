rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user authenticated?
    function isAuth() {
      return request.auth != null;
    }
    
    // Helper: Is this the user themselves?
    function isSelf(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // 1. Users collection
    // Anyone logged in can read a user profile (for search & connection stats)
    // Only the user themselves can update their profile information
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isSelf(userId);
    }

    // 2. Tasks collection
    // Only the user themselves can access or edit their tasks
    match /tasks/{userId}/items/{taskId} {
      allow read, write: if isSelf(userId);
    }

    // Categories collection
    // Only the user themselves can access or edit their categories
    match /categories/{userId}/items/{categoryId} {
      allow read, write: if isSelf(userId);
    }

    // 3. Connections collection
    // Users can read connections they are part of
    // Writes are allowed if authenticated (e.g. creating/deleting friendship documents)
    match /connections/{userId}/friends/{friendId} {
      allow read: if isSelf(userId) || isSelf(friendId);
      allow write: if isAuth() && (isSelf(userId) || isSelf(friendId));
    }

    // 4. Connection Requests collection
    // Users can read or write requests where they are either the sender or receiver
    match /requests/{userId}/friends/{requestId} {
      allow read: if isSelf(userId) || isSelf(requestId);
      allow write: if isSelf(userId) || isSelf(requestId);
    }
  }
}
